{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditEvent",
  "description": "Append-only governance event for significant state transitions. This schema records events; it does not authorize the transition by itself.",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "actor",
    "action",
    "subject_type",
    "subject_id",
    "after_state",
    "reason"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^ae-[A-Za-z0-9._-]+$",
      "description": "Unique audit event identifier."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 event timestamp."
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "description": "Human, coordinator, module, or agent producing the event."
    },
    "action": {
      "type": "string",
      "enum": [
        "created",
        "requested",
        "acknowledged",
        "submitted",
        "reviewed",
        "blocked",
        "failed",
        "accepted_with_limitation",
        "authorized",
        "rejected",
        "dispatched",
        "pinned",
        "deferred"
      ],
      "description": "Governance action being recorded."
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "TaskSpec",
        "RuntimeAuthorization",
        "ExecutionReport",
        "TestExecutionReport",
        "EvidenceManifest",
        "ReviewVerdict",
        "GateResult",
        "FinalVerdict",
        "SubmodulePin",
        "RootGateRequest",
        "Report"
      ],
      "description": "Type of object affected by this event."
    },
    "subject_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the affected object."
    },
    "before_state": {
      "type": "string",
      "description": "Previous state, if known."
    },
    "after_state": {
      "type": "string",
      "minLength": 1,
      "description": "New state after the action."
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "Why the event was recorded."
    },
    "evidence_path": {
      "type": "string",
      "description": "Path to supporting evidence."
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1,
      "description": "Stable caller-provided key for idempotent governance requests."
    },
    "request_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 of the immutable root-gate request identity and payload."
    },
    "root_gate_request": {
      "type": "object",
      "required": [
        "project_id",
        "gate",
        "summary",
        "exact_write_set",
        "evidence_refs"
      ],
      "properties": {
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "exact_write_set": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "dispatch_task_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Concrete task IDs created after an authorized root-gate decision."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": [
              "requested",
              "acknowledged",
              "dispatched"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "then": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          }
        },
        "required": [
          "subject_type"
        ]
      },
      "then": {
        "required": [
          "before_state",
          "dedupe_key",
          "request_hash"
        ],
        "properties": {
          "action": {
            "enum": [
              "requested",
              "acknowledged",
              "authorized",
              "rejected",
              "dispatched"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          },
          "action": {
            "const": "requested"
          }
        },
        "required": [
          "subject_type",
          "action"
        ]
      },
      "then": {
        "required": [
          "root_gate_request"
        ],
        "properties": {
          "before_state": {
            "const": "absent"
          },
          "after_state": {
            "const": "requested"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          },
          "action": {
            "const": "acknowledged"
          }
        },
        "required": [
          "subject_type",
          "action"
        ]
      },
      "then": {
        "properties": {
          "before_state": {
            "const": "requested"
          },
          "after_state": {
            "const": "acknowledged"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          },
          "action": {
            "const": "authorized"
          }
        },
        "required": [
          "subject_type",
          "action"
        ]
      },
      "then": {
        "properties": {
          "before_state": {
            "const": "acknowledged"
          },
          "after_state": {
            "const": "authorized"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          },
          "action": {
            "const": "rejected"
          }
        },
        "required": [
          "subject_type",
          "action"
        ]
      },
      "then": {
        "properties": {
          "before_state": {
            "const": "acknowledged"
          },
          "after_state": {
            "const": "rejected"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "subject_type": {
            "const": "RootGateRequest"
          },
          "action": {
            "const": "dispatched"
          }
        },
        "required": [
          "subject_type",
          "action"
        ]
      },
      "then": {
        "required": [
          "dispatch_task_ids"
        ],
        "properties": {
          "before_state": {
            "const": "authorized"
          },
          "after_state": {
            "const": "dispatched"
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ae-master-plan-v1",
      "timestamp": "2026-06-15T00:00:00Z",
      "actor": "devframe-system-main-coordinator",
      "action": "reviewed",
      "subject_type": "Report",
      "subject_id": "devframe-master-plan-v1-go-no-go-2026-06-15",
      "after_state": "parent_planning_ready",
      "reason": "S00-S09 parent reports completed with pin/runtime/final no-go boundaries.",
      "evidence_path": "integration/reports/devframe-master-plan-v1-go-no-go-2026-06-15.md"
    }
  ]
}
