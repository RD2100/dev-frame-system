{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "title":  "TaskSpec",
    "description":  "Describes a unit of work before execution begins. Produced by a planner agent or human operator, consumed by an executor agent. Construction tasks MUST include gate_0 and conflict_registry. Dual-format contract: this JSON schema is the machine-validatable subset; the SADP protocol defines the human-readable markdown projection with additional fields (Batch, Risk, Allowed Files, Forbidden, Acceptance Gates, Expected Output, Rollback, Report To). See integration-contracts.md for field mapping.",
    "type":  "object",
    "required":  [
                     "task_id",
                     "title",
                     "priority",
                     "status",
                     "description"
                 ],
    "properties":  {
                       "task_id":  {
                                       "type":  "string",
                                       "description":  "Unique task identifier within the session."
                                   },
                       "title":  {
                                     "type":  "string",
                                     "description":  "Short human-readable description of the task."
                                 },
                       "priority":  {
                                        "type":  "string",
                                        "enum":  [
                                                     "P0",
                                                     "P1",
                                                     "P2",
                                                     "P3"
                                                 ],
                                        "description":  "Task priority level."
                                    },
                       "status":  {
                                      "type":  "string",
                                      "enum":  [
                                                   "draft",
                                                   "ready",
                                                   "in_progress",
                                                   "completed",
                                                   "closed",
                                                   "deferred",
                                                   "rejected",
                                                   "accepted_with_limitation",
                                                   "pending_human_decision"
                                               ],
                                      "description":  "Current status of the task. draft: not yet reviewed. ready: approved for dispatch. in_progress: actively being worked. completed: all acceptance criteria met. closed: superseded or no longer needed. deferred: postponed to future phase. rejected: not approved. accepted_with_limitation: accepted with documented constraints. pending_human_decision: requires human authorization."
                                  },
                       "description":  {
                                           "type":  "string",
                                           "minLength":  1,
                                           "description":  "What to do and why -- must be non-empty."
                                       },
                       "depends_on":  {
                                          "type":  "array",
                                          "items":  {
                                                        "type":  "string"
                                                    },
                                          "description":  "Task IDs that must complete before this task can start."
                                      },
                       "assumptions":  {
                                           "type":  "array",
                                           "items":  {
                                                         "type":  "string"
                                                     },
                                           "description":  "Assumptions made when creating this task."
                                       },
                       "risk_notes":  {
                                          "type":  "string",
                                          "description":  "Known risks or concerns."
                                      },
                       "estimated_tools":  {
                                               "type":  "array",
                                               "items":  {
                                                             "type":  "string"
                                                         },
                                               "description":  "Tools likely needed during execution."
                                           },
                       "gate_0":  {
                                      "type":  "object",
                                      "description":  "Gate 0 Reuse-before-Build evidence contract. REQUIRED for any construction task. Boolean self-attestation alone is INVALID.",
                                      "required":  [
                                                       "triggered",
                                                       "inventory_evidence",
                                                       "sufficiency_decision"
                                                   ],
                                      "properties":  {
                                                         "triggered":  {
                                                                           "type":  "boolean",
                                                                           "description":  "Whether Gate 0 was triggered"
                                                                       },
                                                         "trigger_reason":  {
                                                                                "type":  "string",
                                                                                "description":  "Why Gate 0 was triggered"
                                                                            },
                                                         "inventory_evidence":  {
                                                                                    "type":  "object",
                                                                                    "description":  "Evidence of inventory consultation. Must include queried sources and matched capabilities.",
                                                                                    "required":  [
                                                                                                     "queried_sources",
                                                                                                     "matched_capabilities"
                                                                                                 ],
                                                                                    "properties":  {
                                                                                                       "queried_sources":  {
                                                                                                                               "type":  "array",
                                                                                                                               "items":  {
                                                                                                                                             "type":  "string"
                                                                                                                                         },
                                                                                                                               "minItems":  1,
                                                                                                                               "description":  "Files/registries actually consulted"
                                                                                                                           },
                                                                                                       "matched_capabilities":  {
                                                                                                                                    "type":  "array",
                                                                                                                                    "items":  {
                                                                                                                                                  "type":  "string"
                                                                                                                                              },
                                                                                                                                    "description":  "Capability IDs found relevant to the request"
                                                                                                                                },
                                                                                                       "compared_against_request":  {
                                                                                                                                        "type":  "array",
                                                                                                                                        "items":  {
                                                                                                                                                      "type":  "string"
                                                                                                                                                  },
                                                                                                                                        "description":  "What user need was checked against inventory"
                                                                                                                                    }
                                                                                                   }
                                                                                },
                                                         "rules_checked":  {
                                                                               "type":  "array",
                                                                               "items":  {
                                                                                             "type":  "string"
                                                                                         },
                                                                               "description":  "Rule IDs consulted"
                                                                           },
                                                         "lessons_checked":  {
                                                                                 "type":  "array",
                                                                                 "items":  {
                                                                                               "type":  "string"
                                                                                           },
                                                                                 "description":  "Lesson IDs consulted"
                                                                             },
                                                         "sufficiency_decision":  {
                                                                                      "type":  "string",
                                                                                      "enum":  [
                                                                                                   "existing_sufficient",
                                                                                                   "existing_partial",
                                                                                                   "new_delta_required",
                                                                                                   "escalate_uncertain"
                                                                                               ],
                                                                                      "description":  "Result of sufficiency check"
                                                                                  },
                                                         "decision":  {
                                                                          "type":  "string",
                                                                          "enum":  [
                                                                                       "reuse",
                                                                                       "build_delta",
                                                                                       "escalate"
                                                                                   ],
                                                                          "description":  "Final decision"
                                                                      },
                                                         "delta_justification":  {
                                                                                     "type":  "string",
                                                                                     "description":  "Required if sufficiency_decision is new_delta_required"
                                                                                 }
                                                     }
                                  },
                       "conflict_registry":  {
                                                 "type":  "object",
                                                 "description":  "File access scope for parallel dispatch safety. Declare read_set and write_set before execution.",
                                                 "required":  [
                                                                  "read_set",
                                                                  "write_set"
                                                              ],
                                                 "properties":  {
                                                                    "read_set":  {
                                                                                     "type":  "array",
                                                                                     "items":  {
                                                                                                   "type":  "string"
                                                                                               },
                                                                                     "description":  "Files this task will read"
                                                                                 },
                                                                    "write_set":  {
                                                                                      "type":  "array",
                                                                                      "items":  {
                                                                                                    "type":  "string"
                                                                                                },
                                                                                      "description":  "Files this task will modify"
                                                                                  },
                                                                    "protected_files_touched":  {
                                                                                                    "type":  "boolean",
                                                                                                    "description":  "Whether any protected file is in read_set or write_set"
                                                                                                },
                                                                    "conflict_level":  {
                                                                                           "type":  "string",
                                                                                           "enum":  [
                                                                                                        "none",
                                                                                                        "low",
                                                                                                        "high"
                                                                                                    ],
                                                                                           "description":  "Conflict risk level"
                                                                                       }
                                                                }
                                             },
                       "security_report":  {
                                               "type":  "object",
                                               "description":  "Mandatory security report for any task involving external APIs, credentials, or sensitive configuration. Must be completed before task is marked done.",
                                               "properties":  {
                                                                  "scan_status":  {
                                                                                      "type":  "string",
                                                                                      "enum":  ["not_run", "passed", "failed"],
                                                                                      "description":  "Overall scan lifecycle. Planning defaults to not_run and must not imply completed scanning."
                                                                                  },
                                                                  "new_external_api":  {
                                                                                           "type":  "boolean",
                                                                                           "description":  "Does this task introduce or modify external API integration?"
                                                                                       },
                                                                  "new_env_variable":  {
                                                                                           "type":  "boolean",
                                                                                           "description":  "Does this task add or modify environment variables?"
                                                                                       },
                                                                  "env_example_placeholders_only":  {
                                                                                                        "type":  ["boolean", "null"],
                                                                                                        "description":  "Are .env.example files confirmed to contain only placeholders?"
                                                                                                    },
                                                                  "real_key_patterns_found":  {
                                                                                                  "type":  ["boolean", "null"],
                                                                                                  "description":  "Were any real API key patterns (sk-, ghp_, etc.) found in committed files?"
                                                                                              },
                                                                  "staged_diff_secret_scan_run":  {
                                                                                                      "type":  "boolean",
                                                                                                      "description":  "Was secret scanning run on staged diff before commit?"
                                                                                                  },
                                                                  "full_repo_secret_scan_run":  {
                                                                                                    "type":  "boolean",
                                                                                                    "description":  "Was secret scanning run on full repo?"
                                                                                                },
                                                                  "packaging_artifact_scanned":  {
                                                                                                     "type":  "boolean",
                                                                                                     "description":  "Were packaging/release artifacts scanned for secrets?"
                                                                                                 },
                                                                  "key_rotation_needed":  {
                                                                                              "type":  ["boolean", "null"],
                                                                                              "description":  "Does any API key need rotation as a result of this task?"
                                                                                          }
                                                              },
                                               "required":  [
                                                               "scan_status",
                                                               "new_external_api",
                                                                "env_example_placeholders_only",
                                                                "real_key_patterns_found",
                                                                "staged_diff_secret_scan_run",
                                                                "key_rotation_needed"
                                                            ]
                                           },
                       "work_type":  {
                                         "type":  "string",
                                         "enum":  ["coding", "paper", "generic"],
                                         "description":  "Trusted structured entrypoint classification; never inferred from free text."
                                     },
                       "workflow_profile":  {
                                               "$ref":  "#/$defs/workflow_profile",
                                               "description":  "Planned-only deterministic Skill-stage selection. Selection is not execution, review, or acceptance."
                                           }
                   },
    "$defs":  {
                   "workflow_profile":  {
                                               "type":  "object",
                                               "required":  ["contract_version", "resolver_version", "profile_id", "profile_version", "profile_fingerprint", "work_type", "selection_source", "resolution_status", "execution_state", "human_gate_required", "constraints", "ordered_stages"],
                                               "properties":  {
                                                                  "contract_version":  {"const": "workflow-profile.v1"},
                                                                  "resolver_version":  {"const": "workflow-profile-resolver.v1"},
                                                                  "profile_id":  {"type": "string", "minLength": 1},
                                                                  "profile_version":  {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
                                                                  "profile_fingerprint":  {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
                                                                  "work_type":  {"type": "string", "enum": ["coding", "paper", "generic"]},
                                                                  "selection_source":  {"type": "string", "minLength": 1},
                                                                  "resolution_status":  {"type": "string", "enum": ["selected", "human_required"]},
                                                                  "execution_state":  {"const": "planned_only"},
                                                                  "human_gate_required":  {"type": "boolean"},
                                                                  "constraints":  {"$ref": "#/$defs/workflow_profile_constraints"},
                                                                 "ordered_stages":  {
                                                                                           "type": "array",
                                                                                           "items": {"$ref": "#/$defs/workflow_profile_stage"}
                                                                                       }
                                                              },
                                               "allOf":  [
                                                             {
                                                                 "if": {"properties": {"resolution_status": {"const": "selected"}}, "required": ["resolution_status"]},
                                                                 "then": {
                                                                     "properties": {
                                                                         "work_type": {"enum": ["coding", "paper"]},
                                                                         "ordered_stages": {"minItems": 1}
                                                                     }
                                                                 }
                                                             },
                                                             {
                                                                 "if": {"properties": {"resolution_status": {"const": "human_required"}}, "required": ["resolution_status"]},
                                                                 "then": {
                                                                     "properties": {
                                                                         "profile_id": {"const": "unresolved"},
                                                                         "work_type": {"const": "generic"},
                                                                         "human_gate_required": {"const": true},
                                                                         "ordered_stages": {"maxItems": 0}
                                                                     }
                                                                 }
                                                             }
                                                         ],
                                               "additionalProperties":  false
                                           },
                   "workflow_profile_constraints":  {
                                                           "type":  "object",
                                                           "required":  ["read_only", "network_enabled", "require_red_green_evidence"],
                                                           "properties":  {
                                                                              "read_only": {"type": "boolean"},
                                                                              "network_enabled": {"type": "boolean"},
                                                                              "require_red_green_evidence": {"type": "boolean"}
                                                                          },
                                                           "additionalProperties":  false
                                                       },
                   "workflow_profile_stage":  {
                                                     "type":  "object",
                                                     "required":  ["stage_id", "skill_id", "skill_source_path", "skill_fingerprint", "availability", "execution_mode", "permissions", "human_gate", "required_artifacts", "required_evidence"],
                                                     "properties":  {
                                                                        "stage_id": {"type": "string", "minLength": 1},
                                                                        "skill_id": {"type": "string", "minLength": 1},
                                                                        "skill_source_path": {"type": ["string", "null"]},
                                                                        "skill_fingerprint": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
                                                                        "availability": {"type": "string", "enum": ["registered", "missing", "not_adopted", "fingerprint_mismatch"]},
                                                                        "execution_mode": {"type": "string", "enum": ["instruction", "advisory", "tool"]},
                                                                        "permissions": {"$ref": "#/$defs/workflow_profile_permissions"},
                                                                        "human_gate": {"type": "string", "enum": ["none", "required_before_execution"]},
                                                                        "required_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
                                                                        "required_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
                                                                    },
                                                     "additionalProperties":  false
                                                 },
                   "workflow_profile_permissions":  {
                                                           "type":  "object",
                                                           "required":  ["read", "write", "network", "credentials"],
                                                           "properties":  {
                                                                              "read": {"type": "boolean"},
                                                                              "write": {"type": "boolean"},
                                                                              "network": {"type": "boolean"},
                                                                              "credentials": {"const": false}
                                                                          },
                                                           "additionalProperties":  false
                                                       }
               },
    "dependentRequired":  {
                              "work_type": ["workflow_profile"],
                              "workflow_profile": ["work_type"]
                          },
    "allOf":  [
                   {
                       "if": {"properties": {"work_type": {"const": "coding"}}, "required": ["work_type"]},
                       "then": {"properties": {"workflow_profile": {"properties": {"work_type": {"const": "coding"}}}}}
                   },
                   {
                       "if": {"properties": {"work_type": {"const": "paper"}}, "required": ["work_type"]},
                       "then": {"properties": {"workflow_profile": {"properties": {"work_type": {"const": "paper"}}}}}
                   },
                   {
                       "if": {"properties": {"work_type": {"const": "generic"}}, "required": ["work_type"]},
                       "then": {"properties": {"workflow_profile": {"properties": {"work_type": {"const": "generic"}}}}}
                   }
               ],
    "additionalProperties":  false,
    "examples":  [
                     {
                         "task_id":  "t-001",
                         "title":  "Inventory agent-acceptance directory",
                         "priority":  "P1",
                         "status":  "ready",
                         "description":  "Run read-only checks and report findings."
                     }
                 ]
}
