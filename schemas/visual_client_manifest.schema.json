{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rd2100.devframe/schemas/visual-client-manifest",
  "title": "Visual Client Manifest",
  "description": "Default-read-only adapter manifest for reused visual clients such as T3 Code.",
  "type": "object",
  "required": ["version", "name", "reuse", "transport", "endpoints", "surface_mappings", "write_policy"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "reuse": {
      "type": "object",
      "required": ["client", "client_role", "executor", "executor_role", "devframe_role"],
      "properties": {
        "client": { "type": "string", "enum": ["t3code"] },
        "client_role": { "type": "string", "minLength": 1 },
        "executor": { "type": "string", "enum": ["opencode"] },
        "executor_role": { "type": "string", "minLength": 1 },
        "devframe_role": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "transport": {
      "type": "object",
      "required": ["kind", "authority", "client_plan_endpoint", "t3_bridge_endpoint", "t3_environment_endpoint", "t3_auth_session_endpoint", "state_endpoint", "shell_endpoint", "manifest_endpoint"],
      "properties": {
        "kind": { "type": "string", "enum": ["same-origin-http"] },
        "authority": { "type": "string", "enum": ["loopback"] },
        "client_plan_endpoint": { "type": "string", "pattern": "^/" },
        "t3_bridge_endpoint": { "type": "string", "pattern": "^/" },
        "t3_environment_endpoint": { "type": "string", "pattern": "^/" },
        "t3_auth_session_endpoint": { "type": "string", "pattern": "^/" },
        "state_endpoint": { "type": "string", "pattern": "^/" },
        "shell_endpoint": { "type": "string", "pattern": "^/" },
        "manifest_endpoint": { "type": "string", "pattern": "^/" }
      },
      "additionalProperties": false
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/endpoint" },
      "uniqueItems": true
    },
    "surface_mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/surface_mapping" },
      "uniqueItems": true
    },
    "write_policy": {
      "type": "object",
      "required": ["default", "blocked_methods", "allowed_mutation_endpoints", "mutation_status", "human_gate_required_for"],
      "properties": {
        "default": { "type": "string", "enum": ["read-only"] },
        "blocked_methods": {
          "type": "array",
          "items": { "type": "string", "enum": ["POST", "PUT", "PATCH", "DELETE"] },
          "uniqueItems": true,
          "minItems": 3
        },
        "allowed_mutation_endpoints": {
          "type": "array",
          "items": { "$ref": "#/definitions/mutation_endpoint" },
          "uniqueItems": true
        },
        "mutation_status": { "type": "string", "enum": ["future-human-gated-adapter", "human-gated-local-actions"] },
        "human_gate_required_for": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "execute_worker",
              "reply_to_provider",
              "read_browser_profile",
              "persist_raw_transcript",
              "apply_patch",
              "publish_or_deploy"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "supported_methodologies": {
      "type": "array",
      "items": { "$ref": "#/definitions/supported_methodology" },
      "uniqueItems": true
    },
    "governance": {
      "type": "object",
      "required": ["reconReceipt", "rkrRulePath", "reuseAssessment", "primaryClientDecision", "workerDecision", "webAiAdapterDecision", "nextApprovedSlice"],
      "properties": {
        "reconReceipt": { "type": "string", "minLength": 1 },
        "rkrRulePath": { "type": "string", "minLength": 1 },
        "reuseAssessment": { "type": "string", "minLength": 1 },
        "primaryClientDecision": { "type": "string", "minLength": 1 },
        "workerDecision": { "type": "string", "minLength": 1 },
        "webAiAdapterDecision": { "type": "string", "minLength": 1 },
        "nextApprovedSlice": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "endpoint": {
      "type": "object",
      "required": ["id", "path", "method", "contract", "object_types", "mutates", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "path": { "type": "string", "pattern": "^/" },
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "contract": { "type": "string", "minLength": 1 },
        "object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Project",
              "ClientLaunch",
              "T3Bridge",
              "T3Environment",
              "T3AuthSession",
              "ProviderBinding",
              "Agent",
              "DevFrameSession",
              "Run",
              "Gate",
              "Decision",
              "Action"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "mutates": { "type": "boolean" },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "mutation_endpoint": {
      "type": "object",
      "required": ["method", "path", "requires"],
      "properties": {
        "method": { "type": "string", "enum": ["POST"] },
        "path": { "type": "string", "pattern": "^/" },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "surface_mapping": {
      "type": "object",
      "required": ["id", "client_surface", "source_endpoint", "object_types", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "client_surface": { "type": "string", "minLength": 1 },
        "source_endpoint": { "type": "string", "pattern": "^/" },
        "object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Project",
              "ClientLaunch",
              "T3Bridge",
              "T3Environment",
              "T3AuthSession",
              "ProviderBinding",
              "Agent",
              "DevFrameSession",
              "Run",
              "Gate",
              "Decision",
              "Action"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "status": { "type": "string", "enum": ["ready", "adapter-required"] }
      },
      "additionalProperties": false
    },
    "supported_methodology": {
      "type": "object",
      "required": ["skill_id", "title", "display_label", "triggers", "source_kind"],
      "properties": {
        "skill_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "display_label": { "type": "string", "minLength": 1 },
        "triggers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "source_kind": { "type": "string", "minLength": 1 },
        "require_red_green_evidence": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
