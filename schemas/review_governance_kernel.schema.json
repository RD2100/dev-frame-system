{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rd2100.devframe/schemas/review-governance-kernel",
  "title": "Review-First Governance Kernel Packet",
  "description": "Validates the phase-one review-governance lifecycle packet. Enforces authority boundaries: context snapshot immutability, run-success != completion, report != evidence, gate pass requires evidence, projection is derived, and no new top-level governance objects.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "work_item",
    "document_revisions",
    "runs",
    "artifacts",
    "evidence",
    "decisions",
    "principals",
    "projection"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.1$"
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "scope",
        "owner_principal_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "owner_principal_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_profile": {
          "type": "string"
        },
        "repository": {
          "type": "object",
          "properties": {
            "root": {
              "type": "string"
            },
            "default_branch": {
              "type": "string"
            }
          }
        },
        "governance": {
          "type": "object",
          "properties": {
            "evidence_profile": {
              "type": "string"
            },
            "review_policy": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    },
    "work_item": {
      "type": "object",
      "required": [
        "id",
        "project_id",
        "kind",
        "intent",
        "status",
        "input_context_artifact_id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "review"
          ]
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "running",
            "reviewing",
            "blocked",
            "insufficient_evidence",
            "completed"
          ]
        },
        "input_context_artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "governance": {
          "type": "object",
          "properties": {
            "goal": {
              "type": "string"
            },
            "non_goals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "project_scope_refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowed_action_classes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "forbidden_action_classes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "autonomy_level": {
              "type": "string",
              "enum": [
                "read_only",
                "green_only",
                "supervised",
                "total_control"
              ]
            },
            "evidence_required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "completion_criteria": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "stop_lines": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "resume_policy": {
              "type": "string",
              "enum": [
                "manual_only"
              ]
            },
            "goal_contract": {
              "type": "object",
              "properties": {
                "version": {
                  "type": "string"
                },
                "current_phase": {
                  "type": "string"
                },
                "expires_at": {
                  "type": "string"
                },
                "next_predeclared_step": {
                  "type": "object",
                  "properties": {
                    "action_class": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "action_class",
                    "description"
                  ]
                }
              },
              "required": [
                "version",
                "current_phase",
                "next_predeclared_step"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "document_revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "document_family",
          "revision_ref",
          "lifecycle_state"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "document_family": {
            "type": "string",
            "minLength": 1
          },
          "revision_ref": {
            "type": "string",
            "minLength": 1
          },
          "lifecycle_state": {
            "type": "string",
            "enum": [
              "draft",
              "active_plan",
              "adopted",
              "superseded"
            ]
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "work_item_id",
          "principal_id",
          "tool_boundary",
          "input_context_artifact_id",
          "status",
          "claimed_result"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "work_item_id": {
            "type": "string",
            "minLength": 1
          },
          "principal_id": {
            "type": "string",
            "minLength": 1
          },
          "tool_boundary": {
            "type": "string",
            "minLength": 1
          },
          "input_context_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "prepared",
              "running",
              "succeeded",
              "failed",
              "blocked"
            ]
          },
          "claimed_result": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "blocked",
              "inconclusive"
            ]
          }
        },
        "additionalProperties": false
      },
      "minItems": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "kind",
          "producer_ref",
          "content_ref"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "context_snapshot",
              "review_report",
              "command_output",
              "diff_summary",
              "evidence_pack"
            ]
          },
          "producer_ref": {
            "type": "string",
            "minLength": 1
          },
          "content_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "context_snapshot"
                }
              }
            },
            "then": {
              "required": [
                "immutable",
                "source_refs",
                "selected_items",
                "omitted_required_items",
                "freshness",
                "authority_level",
                "redaction_summary",
                "selection_rationale",
                "token_budget",
                "content_hash",
                "knowledge_gap_assessment",
                "required_knowledge",
                "assumption_claims",
                "checked_sources",
                "unresolved_gaps",
                "id",
                "project_id",
                "kind",
                "producer_ref",
                "content_ref"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "project_id": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "context_snapshot",
                    "review_report",
                    "command_output",
                    "diff_summary",
                    "evidence_pack"
                  ]
                },
                "producer_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "content_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "immutable": {
                  "type": "boolean",
                  "enum": [
                    true
                  ]
                },
                "source_refs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1
                },
                "selected_items": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "omitted_required_items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "freshness": {
                  "type": "string",
                  "minLength": 1
                },
                "authority_level": {
                  "type": "string",
                  "minLength": 1
                },
                "redaction_summary": {
                  "type": "string"
                },
                "selection_rationale": {
                  "type": "string",
                  "minLength": 1
                },
                "token_budget": {
                  "type": "integer",
                  "minimum": 1
                },
                "content_hash": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "knowledge_gap_assessment": {
                  "type": "string"
                },
                "required_knowledge": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "assumption_claims": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "checked_sources": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1
                },
                "unresolved_gaps": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          }
        ]
      },
      "minItems": 0
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "claim",
          "supports",
          "source_artifact_id",
          "scope",
          "freshness",
          "observed_result"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "supports": {
            "type": "string",
            "enum": [
              "supports",
              "rejects",
              "inconclusive"
            ]
          },
          "source_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "minLength": 1
          },
          "freshness": {
            "type": "string",
            "minLength": 1
          },
          "observed_result": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 0
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "kind",
          "target_ref",
          "decider_principal_id",
          "outcome",
          "evidence_ids",
          "rationale"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "review",
              "gate",
              "adopt"
            ]
          },
          "target_ref": {
            "type": "string",
            "minLength": 1
          },
          "decider_principal_id": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked",
              "insufficient_evidence",
              "human_required",
              "hard_stop",
              "pause"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "payload": {
            "type": "object"
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "required": [
                "kind",
                "outcome"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "review",
                    "gate"
                  ]
                },
                "outcome": {
                  "const": "pass"
                }
              }
            },
            "then": {
              "properties": {
                "evidence_ids": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minItems": 1
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "review"
                }
              }
            },
            "then": {
              "properties": {
                "outcome": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail",
                    "blocked",
                    "insufficient_evidence"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "gate"
                }
              }
            },
            "then": {
              "properties": {
                "outcome": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail",
                    "blocked",
                    "insufficient_evidence",
                    "human_required",
                    "hard_stop",
                    "pause"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "adopt"
                }
              }
            },
            "then": {
              "properties": {
                "outcome": {
                  "type": "string",
                  "enum": [
                    "pass",
                    "fail",
                    "blocked",
                    "insufficient_evidence"
                  ]
                }
              }
            }
          }
        ]
      },
      "minItems": 0
    },
    "principals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "display_name",
          "authority_scope"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "human",
              "agent",
              "service",
              "policy_runtime"
            ]
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "authority_scope": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "default": [],
      "minItems": 1
    },
    "projection": {
      "type": "object",
      "required": [
        "work_item_id",
        "computed_status",
        "blocked_reason",
        "evidence_summary",
        "decision_summary",
        "allowed_actions"
      ],
      "properties": {
        "work_item_id": {
          "type": "string",
          "minLength": 1
        },
        "computed_status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "running",
            "reviewing",
            "blocked",
            "insufficient_evidence",
            "completed",
            "waiting_for_you",
            "archived"
          ]
        },
        "blocked_reason": {
          "type": "string",
          "description": "Non-empty when computed_status is blocked or insufficient_evidence"
        },
        "evidence_summary": {
          "type": "object",
          "properties": {
            "total_evidence_count": {
              "type": "integer",
              "minimum": 0
            },
            "supporting_count": {
              "type": "integer",
              "minimum": 0
            },
            "rejecting_count": {
              "type": "integer",
              "minimum": 0
            },
            "inconclusive_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "decision_summary": {
          "type": "object",
          "properties": {
            "review_outcome": {
              "type": "string"
            },
            "gate_outcome": {
              "type": "string"
            },
            "latest_decision_id": {
              "type": "string"
            }
          }
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}