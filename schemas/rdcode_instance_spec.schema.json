{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rd2100.github.io/dev-frame-system/schemas/rdcode_instance_spec.schema.json",
  "title": "RD-Code deterministic desktop instance specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "instanceId",
    "controlPlane",
    "ports",
    "paths",
    "rendererEnvironment",
    "desktopEnvironment",
    "build",
    "launch",
    "concurrency",
    "tools"
  ],
  "properties": {
    "version": { "const": 1 },
    "instanceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "controlPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "port", "baseUrl", "clientPlanUrl", "clientManifestUrl"],
      "properties": {
        "host": {
          "type": "string",
          "pattern": "^(?:localhost|127\\.(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]))$"
        },
        "port": { "$ref": "#/$defs/port" },
        "baseUrl": { "type": "string", "minLength": 1 },
        "clientPlanUrl": { "type": "string", "minLength": 1 },
        "clientManifestUrl": { "type": "string", "minLength": 1 }
      }
    },
    "ports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlPlane", "t3Backend", "cdp"],
      "properties": {
        "controlPlane": { "$ref": "#/$defs/port" },
        "t3Backend": { "$ref": "#/$defs/port" },
        "cdp": { "$ref": "#/$defs/port" }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t3Root", "runtimeRoot", "instanceDir", "appDataDir", "localAppDataDir", "t3Home", "specPath", "manifestPath", "buildStampPath", "checkoutLockPath"],
      "properties": {
        "t3Root": { "$ref": "#/$defs/nonEmptyString" },
        "runtimeRoot": { "$ref": "#/$defs/nonEmptyString" },
        "instanceDir": { "$ref": "#/$defs/nonEmptyString" },
        "appDataDir": { "$ref": "#/$defs/nonEmptyString" },
        "localAppDataDir": { "$ref": "#/$defs/nonEmptyString" },
        "t3Home": { "$ref": "#/$defs/nonEmptyString" },
        "specPath": { "$ref": "#/$defs/nonEmptyString" },
        "manifestPath": { "$ref": "#/$defs/nonEmptyString" },
        "buildStampPath": { "$ref": "#/$defs/nonEmptyString" },
        "checkoutLockPath": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "rendererEnvironment": {
      "type": "object",
      "minProperties": 3,
      "propertyNames": { "pattern": "^VITE_DEVFRAME_[A-Z0-9_]+$" },
      "additionalProperties": { "type": "string" }
    },
    "desktopEnvironment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["APPDATA", "LOCALAPPDATA", "T3CODE_HOME", "T3CODE_PORT", "T3CODE_DESKTOP_APP_USER_MODEL_ID", "T3CODE_DISABLE_AUTO_UPDATE"],
      "properties": {
        "APPDATA": { "$ref": "#/$defs/nonEmptyString" },
        "LOCALAPPDATA": { "$ref": "#/$defs/nonEmptyString" },
        "T3CODE_HOME": { "$ref": "#/$defs/nonEmptyString" },
        "T3CODE_PORT": { "type": "string", "pattern": "^[0-9]{1,5}$" },
        "T3CODE_DESKTOP_APP_USER_MODEL_ID": { "$ref": "#/$defs/nonEmptyString" },
        "T3CODE_DISABLE_AUTO_UPDATE": { "const": "1" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceFingerprint", "fingerprint", "toolchain"],
      "properties": {
        "sourceFingerprint": { "$ref": "#/$defs/sha256" },
        "fingerprint": { "$ref": "#/$defs/sha256" },
        "toolchain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["node", "nodePath", "pnpm", "pnpmPath", "command"],
          "properties": {
            "node": { "$ref": "#/$defs/nonEmptyString" },
            "nodePath": { "$ref": "#/$defs/nonEmptyString" },
            "pnpm": { "$ref": "#/$defs/nonEmptyString" },
            "pnpmPath": { "$ref": "#/$defs/nonEmptyString" },
            "command": { "const": "pnpm build:desktop" }
          }
        }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "lockPath"],
      "properties": {
        "mode": { "const": "exclusive-checkout" },
        "lockPath": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodePath", "pnpmPath", "pwshPath"],
      "properties": {
        "nodePath": { "$ref": "#/$defs/nonEmptyString" },
        "pnpmPath": { "$ref": "#/$defs/nonEmptyString" },
        "pwshPath": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readinessTimeoutSeconds", "exitAfterReadySeconds", "forceBuild"],
      "properties": {
        "readinessTimeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 600 },
        "exitAfterReadySeconds": { "type": "integer", "minimum": 0, "maximum": 600 },
        "forceBuild": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
