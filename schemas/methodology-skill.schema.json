{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rd2100.devframe/schemas/methodology-skill",
  "title": "Methodology Skill",
  "description": "Read-only registry entry for a methodology skill surfaced by the control-plane visual state.",
  "type": "object",
  "required": [
    "skill_id",
    "title",
    "source_path",
    "source_kind",
    "triggers",
    "status"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "description": "Stable slug generated from SKILL.md metadata."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "source_kind": {
      "type": "string",
      "const": "local_repository_asset"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "status": {
      "type": "string",
      "const": "registered"
    }
  },
  "additionalProperties": false
}
