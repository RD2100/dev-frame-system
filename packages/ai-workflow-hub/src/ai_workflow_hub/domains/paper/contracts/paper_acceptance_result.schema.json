{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperAcceptanceResult",
  "type": "object",
  "required": ["status", "reasons", "blocking_issues", "reviewer", "evidence_pack_ref"],
  "properties": {
    "status": {"type": "string", "enum": ["accepted", "accepted_with_limitation", "needs_more_evidence", "blocked", "human_required"]},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "issue_type", "severity", "evidence", "blocking"],
        "properties": {
          "issue_id": {"type": "string"},
          "issue_type": {"type": "string", "enum": ["structure", "argument", "citation", "expression", "format", "privacy", "methodology"]},
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "location": {"type": "object", "properties": {"chapter": {"type": "string"}, "section": {"type": "string"}, "paragraph_index": {"type": "integer"}}},
          "evidence": {"type": "string"},
          "recommendation": {"type": "string"},
          "blocking": {"type": "boolean"},
          "human_required": {"type": "boolean", "default": false}
        }
      }
    },
    "non_blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "issue_type", "severity", "evidence", "blocking"],
        "properties": {
          "issue_id": {"type": "string"},
          "issue_type": {"type": "string", "enum": ["structure", "argument", "citation", "expression", "format", "privacy", "methodology"]},
          "severity": {"type": "string", "enum": ["critical", "major", "minor", "info"]},
          "location": {"type": "object", "properties": {"chapter": {"type": "string"}, "section": {"type": "string"}, "paragraph_index": {"type": "integer"}}},
          "evidence": {"type": "string"},
          "recommendation": {"type": "string"},
          "blocking": {"type": "boolean"},
          "human_required": {"type": "boolean", "default": false}
        }
      }
    },
    "required_next_actions": {"type": "array", "items": {"type": "string"}},
    "reviewer": {"type": "string", "enum": ["deterministic_gate", "gpt", "human", "writelab_adapter"]},
    "evidence_pack_ref": {"type": "string"}
  }
}
