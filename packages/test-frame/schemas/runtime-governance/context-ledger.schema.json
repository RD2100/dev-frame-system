{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rd2100.devframe/schemas/runtime-governance/context-ledger",
  "title": "RuntimeGovernanceContextLedger",
  "description": "Append-only context assembly and use ledger. The ledger records packet creation, omission, dispatch, use, and amendment events; it is not a mutable acceptance record.",
  "type": "object",
  "required": [
    "schema_version",
    "context_ledger_id",
    "project_id",
    "goal_id",
    "task_id",
    "created_at",
    "append_only",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.1$"
    },
    "context_ledger_id": {
      "type": "string",
      "pattern": "^cl-[A-Za-z0-9._-]+$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "append_only": {
      "type": "boolean",
      "const": true
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/ledger_entry" },
      "minItems": 1
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "required": ["ref_id", "kind", "uri"],
      "properties": {
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["file", "directory", "url", "artifact", "evidence", "review", "final_verdict", "note"]
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "ledger_entry": {
      "type": "object",
      "required": [
        "ledger_entry_id",
        "entry_index",
        "previous_entry_hash",
        "entry_hash",
        "occurred_at",
        "actor_id",
        "actor_role",
        "event_type",
        "context_packet_id",
        "summary"
      ],
      "properties": {
        "ledger_entry_id": {
          "type": "string",
          "pattern": "^cle-[A-Za-z0-9._-]+$"
        },
        "entry_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonic append position. Reviewers can detect deleted or reordered entries by checking this sequence."
        },
        "previous_entry_hash": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hash of the previous ledger entry, or null for the first entry."
        },
        "entry_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hash of this ledger entry after canonical serialization."
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "actor_role": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "enum": [
            "packet_created",
            "source_added",
            "source_omitted",
            "packet_dispatched",
            "packet_used",
            "amendment_recorded",
            "stale_context_detected",
            "required_context_missing",
            "redaction_applied"
          ]
        },
        "context_packet_id": {
          "type": "string",
          "pattern": "^cp-[A-Za-z0-9._-]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_ref" }
        },
        "resulting_context_packet_id": {
          "type": "string",
          "pattern": "^cp-[A-Za-z0-9._-]+$",
          "description": "New packet produced by an append-only amendment, if any."
        },
        "superseded_context_packet_id": {
          "type": "string",
          "pattern": "^cp-[A-Za-z0-9._-]+$",
          "description": "Prior packet that remains historical and must not be mutated."
        },
        "domain_refs": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null", "array", "object"]
          }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": { "event_type": { "const": "amendment_recorded" } },
            "required": ["event_type"]
          },
          "then": {
            "required": [
              "resulting_context_packet_id",
              "superseded_context_packet_id"
            ]
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "0.1",
      "context_ledger_id": "cl-example",
      "project_id": "devframe-system",
      "goal_id": "goal-runtime-governance",
      "task_id": "task-context-packet",
      "created_at": "2026-07-07T00:00:00Z",
      "append_only": true,
      "entries": [
        {
          "ledger_entry_id": "cle-example-created",
          "entry_index": 0,
          "previous_entry_hash": null,
          "entry_hash": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "occurred_at": "2026-07-07T00:00:00Z",
          "actor_id": "main-coordinator",
          "actor_role": "coordinator",
          "event_type": "packet_created",
          "context_packet_id": "cp-example",
          "summary": "Created contract-only context packet."
        }
      ]
    }
  ]
}
