{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChainEvidence",
  "description": "Role/session chain for an @go run.",
  "type": "object",
  "required": [
    "run_id",
    "executor_id",
    "mode",
    "planner",
    "task",
    "methodology",
    "evidence_files",
    "timestamps"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "task": { "type": ["string", "null"] },
    "task_file": { "type": "string", "minLength": 1 },
    "executor_id": { "type": "string", "minLength": 1 },
    "mode": { "type": ["string", "null"] },
    "planner": { "type": ["string", "null"] },
    "methodology": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "evidence_files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_commands": {
      "type": "object",
      "required": ["finalize"],
      "properties": {
        "finalize": {
          "type": "object",
          "required": [
            "command_args",
            "authority",
            "creates_acceptance",
            "requires_independent_review"
          ],
          "properties": {
            "command": { "type": "string" },
            "command_args": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "cwd": { "type": "string" },
            "authority": { "const": "guidance_only" },
            "creates_acceptance": { "const": false },
            "requires_independent_review": { "const": true },
            "manual": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "reviewer_id": { "type": ["string", "null"] },
    "reviewer_role": { "type": "string" },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "rerun_verified_at": { "type": "string", "format": "date-time" },
    "rerun_summary": { "type": "string" },
    "base_commit": { "type": "string" },
    "head_commit": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string" },
    "timestamps": {
      "type": "object",
      "required": ["created_at"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
